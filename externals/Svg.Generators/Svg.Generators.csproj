<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
      <TargetFrameworks>netstandard2.0</TargetFrameworks>
      <!--<TargetFrameworks>$(AvaloniaBuildFramework)</TargetFrameworks>-->
      <OutputType>Library</OutputType>
        <IsPackable>False</IsPackable>
        <AnalysisLevel>latest</AnalysisLevel>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <EnforceExtendedAnalyzerRules>false</EnforceExtendedAnalyzerRules>
        <Configurations>Debug;Release</Configurations>
        <!-- Disable parallel build for this project to prevent race conditions -->
        <BuildInParallel>false</BuildInParallel>
    </PropertyGroup>

  <PropertyGroup>
    <GeneratorsBasePath>..\SVG\Generators</GeneratorsBasePath>
    <!-- Ensure NuGet assets are resolved relative to the project file, not symbolic links -->
    <MSBuildProjectExtensionsPath>$(MSBuildProjectDirectory)\obj\</MSBuildProjectExtensionsPath>
    <BaseIntermediateOutputPath>$(MSBuildProjectDirectory)\obj\</BaseIntermediateOutputPath>
  </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
        <NoWarn>$(NoWarn);RS1042</NoWarn>
    </PropertyGroup>
    
    <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
        <NoWarn>$(NoWarn);CS1591;CS0618;RS1042</NoWarn>
    </PropertyGroup>

    <ItemGroup>
      <Compile Include="$(GeneratorsBasePath)\**\*.cs" Exclude="$(GeneratorsBasePath)\Properties\**;$(GeneratorsBasePath)\obj\**;$(GeneratorsBasePath)\bin\**" />
    </ItemGroup>

    <ItemGroup>
      <Compile Remove="..\SVG\Generators\AvailableElementsGeneratorNet80.cs" />
    </ItemGroup>

    <ItemGroup>
      <None Include="..\SVG\Generators\AvailableElementsGeneratorNet80.cs" />
    </ItemGroup>

  <!-- Use centralized package versions from Directory.Packages.props -->
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all" />
  </ItemGroup>

</Project>
